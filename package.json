{
  "name": "@apollo/mcp-impostor-host",
  "version": "0.0.1",
  "description": "A test host for MCP Apps — impersonates a real MCP Apps host (e.g. Claude Desktop) for end-to-end testing",
  "license": "MIT",
  "type": "module",
  "bin": {
    "mcp-impostor-host": "./bin/mcp-impostor-host.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./playwright": {
      "types": "./dist/playwright/index.d.ts",
      "default": "./dist/playwright/index.js"
    },
    "./sandbox-server": {
      "default": "./dist/sandbox-server.js"
    }
  },
  "scripts": {
    "build": "tsc && node esbuild.config.js"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.3.2",
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
